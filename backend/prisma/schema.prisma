generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  CANDIDATE
  EMPLOYER
  ADMIN
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  FREELANCE
}

enum WorkMode {
  ON_SITE
  REMOTE
  HYBRID
}

enum JobStatus {
  PENDING
  ACTIVE
  PAUSED
  EXPIRED
  REJECTED
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  ACCEPTED
  REJECTED
}

enum ApplicationTag {
  SHORTLISTED
  ON_HOLD
  POTENTIAL
}

enum ReportTargetType {
  JOB
}

enum ReportReason {
  SPAM
  MISLEADING
  INAPPROPRIATE
  FRAUD
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

enum AuditAction {
  JOB_APPROVED
  JOB_REJECTED
  USER_BANNED
  USER_UNBANNED
  USER_ROLE_CHANGED
  EMPLOYER_VERIFIED
  EMPLOYER_UNVERIFIED
  REPORT_REVIEWED
  REPORT_DISMISSED
  COUPON_CREATED
  COUPON_UPDATED
  PACKAGE_CREATED
  PACKAGE_UPDATED
  CREDITS_GRANTED
  CERTIFICATE_APPROVE
  CERTIFICATE_REJECT
}

enum AuditTargetType {
  JOB
  USER
  REPORT
  COUPON
  PACKAGE
  EMPLOYER_CREDITS
  CANDIDATE_CERTIFICATE
}

enum JobAlertFrequency {
  DAILY
  WEEKLY
}

enum NotificationType {
  APPLICATION_STATUS_CHANGED
  NEW_JOB_FROM_FOLLOWED_COMPANY
  NEW_MATCHED_JOB
  JOB_EXPIRING_SOON
  NEW_APPLICATION
  INTERVIEW_SCHEDULED
  CREDIT_PURCHASED
  CREDIT_LOW
  PAYMENT_FAILED
  SKILL_PROPOSAL_APPROVED
  SKILL_PROPOSAL_REJECTED
  CERTIFICATE_APPROVED
  CERTIFICATE_REJECTED
  SYSTEM
}

enum SkillProposalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum QuestionType {
  TEXT
  YES_NO
}

enum InterviewStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum JobTier {
  BASIC
  PREMIUM
  VIP
}

enum PaymentProvider {
  VNPAY
  MOMO
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
  EXPIRED
}

enum TransactionType {
  PURCHASE_CREDITS
  REFUND
  ADMIN_GRANT
  JOB_POST_DEDUCT
}

enum CouponDiscountType {
  PERCENT
  FIXED
  BONUS_CREDITS
}

enum CouponStatus {
  ACTIVE
  PAUSED
  EXPIRED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id                   String         @id @default(cuid())
  email                String         @unique
  passwordHash         String
  role                 Role           @default(CANDIDATE)
  isVerified           Boolean        @default(false)
  isActive             Boolean        @default(true)
  emailOtp             String?
  emailOtpExpiry       DateTime?
  passwordResetOtp     String?
  passwordResetExpiry  DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  candidate            Candidate?
  employer             Employer?
  refreshTokens        RefreshToken[]
  reports              Report[]
  auditLogs            AuditLog[]
  notifications        Notification[]
  applicationNotes     ApplicationNote[]
}

model Candidate {
  id              String        @id @default(cuid())
  userId          String        @unique
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName        String
  phone           String?
  avatarUrl       String?
  headline        String?
  summary         String?
  location        String?
  skills          String[]
  legacySkills    String[]      @default([])
  preferredJobTypes    JobType[]  @default([])
  preferredWorkModes   WorkMode[] @default([])
  preferredLocations   String[]   @default([])
  preferredIndustries  String[]   @default([])
  preferredSalaryMin   Int?
  preferredSalaryMax   Int?
  openToWork           Boolean    @default(true)
  cvUrl           String?
  cvFileName      String?
  publicSlug      String?       @unique
  isPublicProfile Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  applications      Application[]
  savedJobs         SavedJob[]
  experiences       Experience[]
  educations        Education[]
  jobAlerts         JobAlert[]
  followedCompanies FollowedCompany[]
  cvFiles           CandidateCV[]
  certificates      CandidateCertificate[]
}

enum CertificateCategory {
  LANGUAGE
  IT_CLOUD
  IT_NETWORK
  IT_SECURITY
  IT_DEV
  PROJECT_MGMT
  FINANCE
  MARKETING
  DESIGN
  OTHER
}

enum CertificateLevel {
  BASIC
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum CandidateCertificateStatus {
  PENDING
  APPROVED
  REJECTED
}

model Certificate {
  id              String                @id
  slug            String                @unique
  nameVi          String
  nameEn          String?
  issuer          String
  category        CertificateCategory
  level           CertificateLevel?
  validityMonths  Int?
  description     String?
  createdAt       DateTime              @default(now())
  candidateCerts  CandidateCertificate[]

  @@index([category])
}

model CandidateCertificate {
  id               String                      @id @default(cuid())
  candidateId      String
  candidate        Candidate                   @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  certificateSlug  String
  certificate      Certificate                 @relation(fields: [certificateSlug], references: [slug])
  fileUrl          String
  fileName         String
  fileMime         String
  issuedDate       DateTime?
  expiryDate       DateTime?
  score            String?
  status           CandidateCertificateStatus  @default(PENDING)
  adminNote        String?
  reviewedAt       DateTime?
  reviewedBy       String?
  uploadedAt       DateTime                    @default(now())

  @@index([candidateId, status])
  @@index([status])
}

model CandidateCV {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  fileName    String
  fileUrl     String
  isDefault   Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@index([candidateId])
}

model Experience {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  company     String
  position    String
  startDate   DateTime
  endDate     DateTime?
  isCurrent   Boolean   @default(false)
  description String?
}

model Education {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  school      String
  degree      String
  major       String?
  startYear   Int
  endYear     Int?
}

model Employer {
  id          String        @id @default(cuid())
  userId      String        @unique
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName String
  logoUrl     String?
  website     String?
  industry    String?
  companySize String?
  description String?
  location    String?
  isVerified  Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  jobs        Job[]
  templates   JobTemplate[]
  followedBy  FollowedCompany[]
  creditBalance     EmployerCreditBalance?
  paymentOrders     PaymentOrder[]
  creditTxns        CreditTransaction[]
  couponRedemptions CouponRedemption[]
}

model JobTemplate {
  id             String   @id @default(cuid())
  employerId     String
  employer       Employer @relation(fields: [employerId], references: [id], onDelete: Cascade)
  name           String
  title          String
  description    String
  requirements   String
  benefits       String?
  industry       String
  jobType        JobType  @default(FULL_TIME)
  workMode       WorkMode @default(ON_SITE)
  salaryMin      Int?
  salaryMax      Int?
  salaryCurrency String   @default("VND")
  experience     String?
  location       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Job {
  id             String        @id @default(cuid())
  employerId     String
  employer       Employer      @relation(fields: [employerId], references: [id], onDelete: Cascade)
  title          String
  description    String
  requirements   String
  benefits       String?
  location       String
  jobType        JobType       @default(FULL_TIME)
  workMode       WorkMode      @default(ON_SITE)
  salaryMin      Int?
  salaryMax      Int?
  salaryCurrency String        @default("VND")
  experience     String?
  industry       String
  status         JobStatus     @default(PENDING)
  expiresAt      DateTime
  viewCount      Int           @default(0)
  isFlagged      Boolean       @default(false)
  flagReason     String?
  tier           JobTier       @default(BASIC)
  boostedUntil   DateTime?
  skillSlugs     String[]      @default([])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  applications        Application[]
  savedBy             SavedJob[]
  screeningQuestions  ScreeningQuestion[]
  creditTxns          CreditTransaction[]

  @@index([status, expiresAt])
  @@index([isFlagged])
  @@index([tier, boostedUntil])
}

model Application {
  id          String            @id @default(cuid())
  jobId       String
  job         Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidateId String
  candidate   Candidate         @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  cvUrl       String
  coverLetter String?
  status      ApplicationStatus @default(PENDING)
  tag         ApplicationTag?
  note        String?
  appliedAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([jobId, candidateId])
  @@index([jobId, candidateId])
  statusHistory     ApplicationStatusHistory[]
  internalNotes     ApplicationNote[]
  screeningAnswers  ScreeningAnswer[]
  interviews        InterviewSchedule[]
}

model ApplicationNote {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  authorId      String
  author        User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content       String
  createdAt     DateTime    @default(now())

  @@index([applicationId])
}

model ScreeningQuestion {
  id         String          @id @default(cuid())
  jobId      String
  job        Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)
  question   String
  type       QuestionType    @default(TEXT)
  isRequired Boolean         @default(true)
  order      Int             @default(0)
  createdAt  DateTime        @default(now())
  answers    ScreeningAnswer[]

  @@index([jobId])
}

model ScreeningAnswer {
  id            String            @id @default(cuid())
  questionId    String
  question      ScreeningQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  applicationId String
  application   Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  answer        String
  createdAt     DateTime          @default(now())

  @@unique([questionId, applicationId])
  @@index([applicationId])
}

model SavedJob {
  id          String    @id @default(cuid())
  jobId       String
  job         Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  savedAt     DateTime  @default(now())

  @@unique([jobId, candidateId])
}

model FollowedCompany {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  employerId  String
  employer    Employer  @relation(fields: [employerId], references: [id], onDelete: Cascade)
  followedAt  DateTime  @default(now())

  @@unique([candidateId, employerId])
  @@index([candidateId])
}

model ApplicationStatusHistory {
  id            String             @id @default(cuid())
  applicationId String
  application   Application        @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  fromStatus    ApplicationStatus?
  toStatus      ApplicationStatus
  changedById   String?
  note          String?
  createdAt     DateTime           @default(now())

  @@index([applicationId, createdAt])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Report {
  id          String           @id @default(cuid())
  reporterId  String
  reporter    User             @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  targetType  ReportTargetType
  targetId    String
  reason      ReportReason
  description String?
  status      ReportStatus     @default(PENDING)
  adminNote   String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([status, createdAt])
}

model AuditLog {
  id         String          @id @default(cuid())
  adminId    String
  admin      User            @relation(fields: [adminId], references: [id], onDelete: Cascade)
  action     AuditAction
  targetType AuditTargetType
  targetId   String
  metadata   Json?
  createdAt  DateTime        @default(now())

  @@index([adminId])
  @@index([action, createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  link      String?
  metadata  Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, isRead, createdAt])
}

model JobAlert {
  id          String            @id @default(cuid())
  candidateId String
  candidate   Candidate         @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  industries  String[]
  locations   String[]
  jobTypes    JobType[]
  frequency   JobAlertFrequency @default(DAILY)
  isActive    Boolean           @default(true)
  lastSentAt  DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model InterviewSchedule {
  id            String          @id @default(cuid())
  applicationId String
  application   Application     @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  scheduledAt   DateTime
  location      String?
  meetingLink   String?
  note          String?
  status        InterviewStatus @default(PENDING)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([applicationId])
}

model CreditPackage {
  id           String         @id @default(cuid())
  name         String
  tier         JobTier
  creditAmount Int
  priceVnd     Int
  bonusCredits Int            @default(0)
  isActive     Boolean        @default(true)
  sortOrder    Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  orders       PaymentOrder[]

  @@index([tier, isActive])
}

model EmployerCreditBalance {
  id             String   @id @default(cuid())
  employerId     String   @unique
  employer       Employer @relation(fields: [employerId], references: [id], onDelete: Cascade)
  basicCredits   Int      @default(0)
  premiumCredits Int      @default(0)
  vipCredits     Int      @default(0)
  updatedAt      DateTime @updatedAt
}

model PaymentOrder {
  id                   String              @id @default(cuid())
  employerId           String
  employer             Employer            @relation(fields: [employerId], references: [id], onDelete: Cascade)
  packageId            String
  package              CreditPackage       @relation(fields: [packageId], references: [id])
  couponId             String?
  coupon               Coupon?             @relation(fields: [couponId], references: [id])
  provider             PaymentProvider
  status               PaymentStatus       @default(PENDING)
  amountGross          Int
  discountAmount       Int                 @default(0)
  amountNet            Int
  qrCodeUrl            String?
  payUrl               String?
  providerTxnRef       String?             @unique
  providerResponseCode String?
  ipnPayload           Json?
  expiresAt            DateTime
  paidAt               DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  transactions         CreditTransaction[]
  redemptions          CouponRedemption[]

  @@index([employerId, status])
  @@index([status, createdAt])
}

model CreditTransaction {
  id             String          @id @default(cuid())
  employerId     String
  employer       Employer        @relation(fields: [employerId], references: [id], onDelete: Cascade)
  type           TransactionType
  tier           JobTier?
  delta          Int
  balanceAfter   Int
  paymentOrderId String?
  paymentOrder   PaymentOrder?   @relation(fields: [paymentOrderId], references: [id])
  jobId          String?
  job            Job?            @relation(fields: [jobId], references: [id])
  adminUserId    String?
  note           String?
  createdAt      DateTime        @default(now())

  @@index([employerId, createdAt])
}

model Coupon {
  id               String             @id @default(cuid())
  code             String             @unique
  name             String
  description      String?
  discountType     CouponDiscountType
  discountValue    Int
  bonusCredits     Int                @default(0)
  appliesTo        JobTier?
  minAmount        Int?
  maxRedemptions   Int?
  redeemedCount    Int                @default(0)
  perEmployerLimit Int                @default(1)
  startsAt         DateTime
  endsAt           DateTime
  status           CouponStatus       @default(ACTIVE)
  createdByAdminId String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  orders           PaymentOrder[]
  redemptions      CouponRedemption[]

  @@index([status, endsAt])
}

model CouponRedemption {
  id             String       @id @default(cuid())
  couponId       String
  coupon         Coupon       @relation(fields: [couponId], references: [id], onDelete: Cascade)
  employerId     String
  employer       Employer     @relation(fields: [employerId], references: [id], onDelete: Cascade)
  paymentOrderId String
  paymentOrder   PaymentOrder @relation(fields: [paymentOrderId], references: [id], onDelete: Cascade)
  redeemedAt     DateTime     @default(now())

  @@unique([couponId, employerId, paymentOrderId])
  @@index([couponId])
}

enum SkillCategory {
  IT
  SU_PHAM
  KINH_TE
  Y_TE
  MARKETING
  KY_THUAT
  THIET_KE
  NGON_NGU
  KY_NANG_MEM
  KHAC
}

model Skill {
  id          String        @id @default(cuid())
  slug        String        @unique
  nameVi      String
  nameEn      String?
  category    SkillCategory
  aliases     String[]
  jobCount    Int           @default(0)
  trending30d Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  proposals   SkillProposal[]

  @@index([category, jobCount])
}

model SkillProposal {
  id              String              @id @default(cuid())
  proposedById    String
  proposedByRole  Role
  name            String
  nameEn          String?
  category        SkillCategory
  reason          String?
  status          SkillProposalStatus @default(PENDING)
  adminNote       String?
  resolvedById    String?
  resolvedAt      DateTime?
  createdSkillId  String?
  createdSkill    Skill?              @relation(fields: [createdSkillId], references: [id])
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([status, createdAt])
  @@index([proposedById])
}
